# GemBots Arena — BSC Contract Configuration
# Copy this file to .env and fill in your values

# Deployer private key (with 0x prefix)
DEPLOYER_PRIVATE_KEY=your-private-key-here

# BSC RPC URLs (defaults provided in hardhat.config.js)
BSC_RPC_URL=https://bsc-dataseed.binance.org/
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545/

# BSCScan API key for contract verification
BSCSCAN_API_KEY=your-bscscan-api-key

# Oracle address (backend service that resolves battles)
ORACLE_ADDRESS=your-oracle-wallet-address
