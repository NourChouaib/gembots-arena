// /register command
bot.command('register', async (ctx) => {
  if (isGroup(ctx)) return; // Only in private

  const userId = ctx.from.id;
  try {
    const existingApiKey = await getUserApiKey(userId);
    if (existingApiKey) {
      return ctx.reply(`✅ *Вы уже зарегистрированы!*\n\n🔑 *API ключ:* \`${existingApiKey}\``, {
        parse_mode: 'Markdown',
        ...createMainMenu()
      });
    }

    ctx.reply('🔄 *Регистрирую вас...*', { parse_mode: 'Markdown' });
    const response = await makeApiRequest('/api/v1/bots/register', 'POST', {
      name: `TelegramBot_${userId}`,
      telegram_id: userId
    });

    if (response.api_key) {
      await setUserApiKey(userId, response.api_key);
      ctx.reply(`✅ *Регистрация успешна!*\n\n🔑 *API ключ:* \`${response.api_key}\`\n\n💡 Сохраните ключ!`, {
        parse_mode: 'Markdown',
        ...createMainMenu()
      });
    } else {
      ctx.reply('❌ *Ошибка регистрации* — попробуйте позже', { parse_mode: 'Markdown' });
    }
  } catch (error) {
    console.error('Register error:', error);
    ctx.reply(`❌ *Ошибка:* ${error.message}`, { parse_mode: 'Markdown' });
  }
});

// /predict command
bot.command('predict', async (ctx) => {
  if (isGroup(ctx)) return; // Only in private

  const userId = ctx.from.id;
  const args = ctx.message.text.split(' ').slice(1);

  if (args.length === 0) {
    return ctx.reply(`💡 *Использование:* \`/predict <mint> [confidence]\`\n\n*Пример:* \`/predict EPjFW...Dt1v 80\``, {
      parse_mode: 'Markdown',
      ...Markup.inlineKeyboard([
        [Markup.button.callback('🎯 Make Prediction', 'menu_predict')],
        [Markup.button.callback('← Main Menu', 'menu_main')]
      ])
    });
  }

  const mint = args[0];
  const confidence = parseInt(args[1]) || 70;
  if (confidence < 1 || confidence > 100) {
    return ctx.reply('❌ *Confidence должен быть от 1 до 100*', { parse_mode: 'Markdown' });
  }

  try {
    const apiKey = await getUserApiKey(userId);
    if (!apiKey) {
      return ctx.reply('❌ *Сначала /register*', { parse_mode: 'Markdown' });
    }

    const response = await makeApiRequest('/api/v1/predictions', 'POST', {
      mint, confidence, direction: 'up'
    }, apiKey);

    ctx.reply(`✅ *Prediction создан!*\n\n🪙 ${mint.substring(0, 8)}...\n📈 UP ↗️ | 🎯 ${confidence}%\n🆔 ${response.id || 'N/A'}`, {
      parse_mode: 'Markdown',
      ...createMainMenu()
    });
  } catch (error) {
    console.error('Predict error:', error);
    ctx.reply(`❌ *Ошибка:* ${error.message}`, { parse_mode: 'Markdown' });
  }
});

// /history command
bot.command('history', async (ctx) => {
  if (isGroup(ctx)) return;

  const userId = ctx.from.id;
  try {
    const apiKey = await getUserApiKey(userId);
    if (!apiKey) return ctx.reply('❌ *Сначала /register*', { parse_mode: 'Markdown' });

    const response = await makeApiRequest('/api/v1/predictions?limit=5', 'GET', null, apiKey);
    if (!response || !response.length) {
      return ctx.reply('📜 *История пуста*\n\n🚀 Создайте первый prediction!', {
        parse_mode: 'Markdown',
        ...createMainMenu()
      });
    }

    let msg = '━━━ 📜 *History* ━━━\n\n';
    response.forEach((pred, i) => {
      const status = pred.status === 'pending' ? '⏳' : pred.status === 'won' ? '✅' : pred.status === 'lost' ? '❌' : '❓';
      msg += `${status} ${pred.mint ? pred.mint.substring(0, 8) + '...' : '?'} | ${pred.direction || 'UP'} ${pred.confidence || 70}%\n`;
    });

    ctx.reply(msg, { parse_mode: 'Markdown', ...createMainMenu() });
  } catch (error) {
    console.error('History error:', error);
    ctx.reply(`❌ *Ошибка:* ${error.message}`, { parse_mode: 'Markdown' });
  }
});

